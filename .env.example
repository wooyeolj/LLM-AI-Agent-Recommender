# 백엔드 설정
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Streamlit → FastAPI 연결 주소 (Docker 사용 시 자동 설정됨, 로컬은 기본값 사용)
BACKEND_URL=http://localhost:8000

# LLM 엔드포인트 — 로컬 Ollama, Colab ngrok URL 등으로 교체 가능
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b
MODEL_DEVICE=cpu

# 임베딩 / 리랭킹 모델
EMBEDDING_MODEL=dragonkue/BGE-m3-ko
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 기타 설정
CACHE_TTL_DAYS=30
HF_TOP_N=30

# GitHub API 토큰 (선택) — 없으면 시간당 60회, 있으면 5000회
# 발급: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
GITHUB_TOKEN=your_github_token_here
