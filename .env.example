# 백엔드 설정
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

#로컬 실행용 URL
BACKEND_URL=http://localhost:8000

# LLM 엔드포인트
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b
MODEL_DEVICE=cpu

# 임베딩 / 리랭킹 모델
EMBEDDING_MODEL=dragonkue/BGE-m3-ko
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 같은 키워드 재크롤링 방지 기간
CACHE_TTL_DAYS=14

# GitHub API 토큰 (선택) — 없으면 시간당 60회, 있으면 5000회
# 발급: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
GITHUB_TOKEN=

# ChromaDB 저장 경로 (기본값: <프로젝트루트>/data/chroma_data)
# CHROMA_DB_PATH=
